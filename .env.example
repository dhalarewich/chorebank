# Required by Docker Compose and Node.js installations.
AUTH_SECRET=replace-with-a-random-base64url-secret
SETUP_TOKEN=replace-with-a-second-random-base64url-secret
POSTGRES_PASSWORD=replace-with-a-long-unique-password
DEFAULT_HOUSEHOLD_ID=home

# Docker Compose only (optional).
APP_PORT=3000

# Node.js with an existing PostgreSQL database only.
DATABASE_URL=postgresql://chorebank:replace-with-password@localhost:5432/chorebank?schema=public
DIRECT_URL=postgresql://chorebank:replace-with-password@localhost:5432/chorebank?schema=public
