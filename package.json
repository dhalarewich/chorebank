{
  "name": "chorebank",
  "version": "1.0.0",
  "description": "A private, family chore and rewards board.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dhalarewich/chorebank.git"
  },
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "vercel-build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "setup": "tsx scripts/setup-household.ts",
    "password:reset": "node scripts/reset-parent-password.mjs",
    "pitr:verify": "tsx scripts/pitr-drill-verify.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "^3.0.2",
    "framer-motion": "^12.35.0",
    "next": "16.2.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.0.0"
  }
}
